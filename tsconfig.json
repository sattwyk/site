{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "strictNullChecks": true,
    "baseUrl": ".",
    "paths": {
      "@components/*": [
        "./src/components/*"
      ],
      "@layouts/*": [
        "./src/layouts/*"
      ],
      "@lib/*": [
        "./src/lib/*"
      ],
      "@styles/*": [
        "./src/styles/*"
      ],
      "@consts": [
        "./src/consts.ts"
      ],
      "@types": [
        "./src/types.ts"
      ]
    }
  },
  "include": [
    "./worker-configuration.d.ts"
  ]
}